<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>WinCoD - My Orders</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Orbitron', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a0404;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }
        .moving-lines {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.35; pointer-events: none;
        }
        .line {
            position: absolute; background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px; width: 100%; animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        .orders-container {
            position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 40px 20px;
        }
        .glass-card {
            background: rgba(20, 5, 5, 0.85); backdrop-filter: blur(12px);
            border-radius: 32px; border: 1px solid rgba(255, 50, 50, 0.6); padding: 40px; width: 100%;
        }
        .user-info {
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 20px; flex-wrap: wrap;
        }
        .user-email {
            color: #ff9999; font-weight: bold; background: rgba(255,255,255,0.05); padding: 6px 12px; border-radius: 30px;
        }
        .btn-back, .support-link {
            background: linear-gradient(135deg, #cc0000, #660000);
            color: white; border: none; padding: 8px 16px; border-radius: 30px;
            text-decoration: none; font-weight: bold; transition: 0.2s; display: inline-block; cursor: pointer;
        }
        .support-link {
            background: rgba(204, 0, 0, 0.25);
            backdrop-filter: blur(8px);
            color: #ffcccc;
            border: 1px solid rgba(255, 80, 80, 0.5);
            margin-left: 10px;
        }
        .support-link:hover {
            background: rgba(204, 0, 0, 0.45);
            color: white;
            transform: translateY(-1px);
        }
        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px #ff0000;
        }
        h1 { color: white; font-size: 32px; text-align: center; margin-bottom: 30px; }
        .table-wrapper { overflow-x: auto; margin-top: 20px; }
        table { width: 100%; border-collapse: collapse; background: rgba(0,0,0,0.4); border-radius: 12px; overflow: hidden; min-width: 900px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1); }
        th { background: rgba(134, 0, 0, 0.4); color: white; font-weight: 600; }
        td { color: #ddd; }
        .tracking { font-family: monospace; letter-spacing: 4px; font-weight: bold; color: #ff5506; }
        .no-orders { text-align: center; color: #aaa; padding: 40px; font-size: 18px; }
        .duration-lifetime { color: #00ff80; font-weight: bold; }
        .status-active { color: #4bdd83; font-weight: normal; }
        .status-expired { color: #ff0000c0; font-weight: bold; }
        .days-left { font-size: 14px; color: rgb(83, 35, 35); }
        .modal {
            display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.8); backdrop-filter: blur(8px); align-items: center; justify-content: center;
        }
        .modal.show { display: flex !important; }
        .glass-modal {
            background: rgba(20, 5, 5, 0.95); backdrop-filter: blur(16px); border-radius: 32px;
            border: 1px solid rgba(255, 50, 50, 0.8); box-shadow: 0 0 50px rgba(255, 0, 0, 0.5);
            padding: 40px; max-width: 500px; width: 90%; text-align: center; animation: fadeInUp 0.3s ease;
        }
        .modal-icon { font-size: 48px; margin-bottom: 16px; }
        .glass-modal h3 { color: #ff6666; font-size: 28px; margin-bottom: 20px; }
        .glass-modal p { color: rgba(255, 200, 200, 0.9); font-size: 16px; line-height: 1.5; margin-bottom: 30px; }
        .modal-btn {
            background: linear-gradient(135deg, #cc0000, #660000); color: white; padding: 12px 24px; border-radius: 40px;
            font-weight: bold; border: none; cursor: pointer; transition: 0.2s; width: auto; font-size: 16px;
        }
        .modal-btn:hover { transform: scale(1.02); box-shadow: 0 0 15px #ff0000; }
        .telegram-link { color: #ff9999; text-decoration: none; font-weight: bold; }
        .telegram-link:hover { text-decoration: underline; color: white; }
        @media (max-width: 768px) {
            .orders-container { padding: 20px; }
            .glass-card { padding: 24px; }
            th, td { padding: 8px; font-size: 12px; }
            .user-info { flex-direction: column; align-items: stretch; }
            .user-info > div { display: flex; justify-content: center; gap: 10px; }
        }
    </style>
</head>
<body>
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>
    <div class="orders-container">
        <div class="glass-card">
            <div class="user-info">
                <span class="user-email">𝕎 : <%= user.username %></span>
                <div>
                    <a href="/shop" class="btn-back">← Back to Shop</a>
                    <button id="supportBtn" class="support-link">𝕎 Support</button>
                </div>
            </div>
            <h1>My Orders</h1>
            <% if (orders && orders.length > 0) { %>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Order ID</th><th>Product</th><th>Amount</th><th>Duration</th>
                                <th>Expiration</th><th>Status</th><th>Tracking Number</th><th>Order Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { 
                                let expireDate = null; let daysLeft = null; let isExpired = false;
                                let isLifetime = (order.duration_days === 0);
                                if (!isLifetime && order.created_at) {
                                    const createdDate = new Date(order.created_at);
                                    expireDate = new Date(createdDate);
                                    expireDate.setDate(createdDate.getDate() + order.duration_days);
                                    const now = new Date();
                                    daysLeft = Math.ceil((expireDate - now) / (1000 * 60 * 60 * 24));
                                    isExpired = daysLeft < 0;
                                    if (isExpired) daysLeft = 0;
                                }
                            %>
                            <tr>
                                <td><%= order.id %></td>
                                <td><%= order.product_name %></td>
                                <td>$<%= parseFloat(order.amount).toFixed(2) %></td>
                                <td>
                                    <% if (isLifetime) { %>
                                        <span class="duration-lifetime">Lifetime</span>
                                    <% } else { %>
                                        <%= order.duration_days %> days
                                    <% } %>
                                </td>
                                <td>
                                    <% if (isLifetime) { %>
                                        Never expires
                                    <% } else if (expireDate) { %>
                                        <%= expireDate.toLocaleDateString() %>
                                        <div class="days-left">
                                            <% if (isExpired) { %>Expired<% } else { %><%= daysLeft %> day(s) left<% } %>
                                        </div>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td>
                                    <% if (isLifetime) { %>
                                        <span class="status-active">Active</span>
                                    <% } else if (isExpired) { %>
                                        <span class="status-expired">Expired</span>
                                    <% } else { %>
                                        <span class="status-active">Active</span>
                                    <% } %>
                                </td>
                                <td class="tracking"><%= order.tracking_number %></td>
                                <td><%= new Date(order.created_at).toLocaleString() %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="no-orders">No orders yet. <a href="/shop" style="color:#ff6666;">Go to shop</a> to make your first purchase.</div>
            <% } %>
        </div>
    </div>

    <!-- Support Modal (Telegram message) -->
    <div id="supportModal" class="modal">
        <div class="glass-modal">
            <div class="modal-icon">📢</div>
            <h3>Support Information</h3>
            <p>Please contact us on <a href="https://t.me/OU71C" target="_blank" class="telegram-link">Telegram</a> if none of our support team responds via email within 24 hours.</p>
            <p>Thank you for your patience.</p>
            <button id="closeSupportBtn" class="modal-btn">Close</button>
        </div>
    </div>

    <script>
        const supportBtn = document.getElementById('supportBtn');
        const supportModal = document.getElementById('supportModal');
        const closeSupport = document.getElementById('closeSupportBtn');
        if (supportBtn && supportModal) {
            supportBtn.addEventListener('click', () => supportModal.classList.add('show'));
            if (closeSupport) closeSupport.addEventListener('click', () => supportModal.classList.remove('show'));
            supportModal.addEventListener('click', (e) => { if (e.target === supportModal) supportModal.classList.remove('show'); });
        }
    </script>
</body>
</html>