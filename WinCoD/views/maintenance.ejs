<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>WinCoD – Maintenance</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Orbitron', 'Segoe UI', sans-serif;
            background: #0a0404;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            position: relative;
        }
        .moving-lines {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.3; pointer-events: none;
        }
        .line {
            position: absolute; background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px; width: 100%; animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        .glass-card {
            background: rgba(20, 5, 5, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            border: 1px solid rgba(255, 50, 50, 0.6);
            padding: 40px;
            max-width: 550px;
            width: 100%;
            text-align: center;
            position: relative;
            z-index: 1;
        }
        h1 { color: #ff6666; font-size: 36px; margin-bottom: 20px; }
        p { color: #ddd; font-size: 16px; line-height: 1.5; margin-bottom: 20px; }
        .icon-container {
            font-size: 80px;
            margin-bottom: 20px;
            display: inline-block;
            animation: breathe 2s ease-in-out infinite;
        }
        .icon {
            display: inline-block;
            transition: opacity 0.15s ease;
            opacity: 1;
        }
        .small { font-size: 12px; color: #888; }
        @keyframes breathe {
            0% { transform: scale(1); opacity: 0.7; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 0.7; }
        }
    </style>
</head>
<body>
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>
    <div class="glass-card">
        <div class="icon-container">
            <span class="icon" id="animatedIcon">🔧</span>
        </div>
        <h1>Under Maintenance</h1>
        
        <p><strong>•</strong> <strong>WinCoD</strong> is currently undergoing scheduled maintenance <strong>•</strong></p>

        <p><strong>• All Subscriptions Are Being Suspended •</strong></p>
        
            <p><strong>•</strong> Please check back later <strong>&</strong> Thank You For Your Patience. <strong>•</strong></p>
       
    </div>

    <script>
        const iconElement = document.getElementById('animatedIcon');
        const icons = ['🔧', '𝕎'];
        let index = 0;

        setInterval(() => {
            // Fade out, change icon, fade in
            iconElement.style.opacity = '0';
            setTimeout(() => {
                index = (index + 1) % icons.length;
                iconElement.textContent = icons[index];
                iconElement.style.opacity = '1';
            }, 100); // shorter fade for faster change
        }, 1000); // change every 1 second
    </script>
</body>
</html>