<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WinCod Cheats - Payment</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        /* ---------- Spacing fix for user info ---------- */
        .user-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            gap: 20px;
        }
        .user-info div {
            display: flex;
            gap: 10px;
            align-items: center;
        }
        .logout-btn, .support-btn {
            margin-left: 0 !important;
        }
        /* ---------- Modal & support button styles (same as shop) ---------- */
        .modal {
            display: none;
            position: fixed;
            z-index: 10000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            align-items: center;
            justify-content: center;
        }
        .modal.show {
            display: flex !important;
        }
        .glass-modal {
            background: rgba(20, 5, 5, 0.95);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(255, 50, 50, 0.8);
            box-shadow: 0 0 50px rgba(255, 0, 0, 0.5);
            padding: 40px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            animation: fadeInUp 0.3s ease;
        }
        .modal-icon {
            font-size: 48px;
            margin-bottom: 16px;
        }
        .glass-modal h3 {
            color: #ff6666;
            font-size: 28px;
            margin-bottom: 20px;
        }
        .glass-modal p {
            color: rgba(255, 200, 200, 0.9);
            font-size: 16px;
            line-height: 1.5;
            margin-bottom: 30px;
        }
        .modal-btn {
            background: linear-gradient(135deg, #cc0000, #660000);
            color: white;
            padding: 12px 24px;
            border-radius: 40px;
            font-weight: bold;
            border: none;
            cursor: pointer;
            transition: 0.2s;
            width: auto;
            font-size: 16px;
        }
        .modal-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 0 15px #ff0000;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .support-btn {
            background: rgba(204, 0, 0, 0.25);
            backdrop-filter: blur(8px);
            color: #ffcccc;
            padding: 6px 16px;
            border-radius: 30px;
            text-decoration: none;
            transition: all 0.2s ease;
            display: inline-block;
            margin-left: 10px;
            font-weight: 600;
            border: 1px solid rgba(255, 80, 80, 0.5);
            cursor: pointer;
        }
        .support-btn:hover {
            background: rgba(204, 0, 0, 0.45);
            color: white;
            border-color: #ff6666;
            box-shadow: 0 0 12px rgba(255, 0, 0, 0.5);
            transform: translateY(-1px);
        }
        /* Payment page additional styles */
        .product-info {
            background: rgba(0,0,0,0.3);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 25px;
            text-align: center;
        }
        .product-name {
            font-size: 24px;
            font-weight: bold;
            color: #ff6666;
        }
        .product-amount {
            font-size: 32px;
            font-weight: 800;
            margin: 10px 0;
            color: #ff4d4d;
            text-shadow: 0 0 5px rgba(255,0,0,0.5);
        }
        .duration-text {
            font-size: 14px;
            opacity: 0.8;
            margin-top: 8px;
        }
        .duration-lifetime {
            color: #2ecc71;
            font-weight: bold;
        }
        /* Loading overlay with moving lines (same as background) */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 20000;
            display: none;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }
        .loading-overlay.show {
            display: flex;
        }
        .loading-lines {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.4;
            pointer-events: none;
        }
        .loading-lines .line {
            position: absolute;
            background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px;
            width: 100%;
            animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .loading-lines .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .loading-lines .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .loading-lines .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .loading-lines .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .loading-lines .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .loading-lines .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        .red-spinner {
            width: 80px;
            height: 80px;
            border: 6px solid rgba(255, 0, 0, 0.2);
            border-top: 6px solid #ff0000;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            z-index: 1;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .loading-overlay p {
            color: #ff9999;
            margin-top: 20px;
            font-family: 'Orbitron', monospace;
            font-size: 16px;
            letter-spacing: 1px;
            z-index: 1;
        }
    </style>
    <script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=USD&intent=capture&components=buttons" data-namespace="paypal"></script>
</head>
<body class="auth-page">
    <!-- Animated moving lines background (global) -->
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>

    <div class="glass-card">
        <div class="user-info">
            <span class="user-email">𝕎 : <%= username %></span>
            <div>
                <button id="logoutBtn" class="logout-btn">Logout</button>
                <a href="/contact" class="support-btn">𝕎 Support</a>
            </div>
        </div>
        <div class="logo">
            <div class="logo-icon">𝕎</div>
        </div>
        <h1>Complete Payment</h1>
        <div class="product-info">
            <div class="product-name"><%= productName %></div>
            <div class="product-amount">$<%= amount %> USD</div>
            <div class="duration-text">
                Access duration: 
                <% if (duration === '0 days' || duration === 'Lifetime') { %>
                    <span class="duration-lifetime">Lifetime</span>
                <% } else { %>
                    <%= duration %>
                <% } %>
            </div>
        </div>
        <div id="paymentStatus"></div>
        <div id="paypal-button-container" class="paypal-container"></div>
    </div>

    <!-- Loading overlay with moving lines -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-lines">
            <div class="line"></div><div class="line"></div><div class="line"></div>
            <div class="line"></div><div class="line"></div><div class="line"></div>
        </div>
        <div class="red-spinner"></div>
        <p>Processing payment, please wait...</p>
    </div>

    <!-- Disclaimer modal -->
    <div id="disclaimerModal" class="modal">
        <div class="glass-modal">
            <div class="modal-icon">⚠️</div>
            <h3>Disclaimer</h3>
            <p>Cheating in games can get you <strong>permanent ban</strong>.<br>
            We are <strong>not responsible</strong> if you get banned using our cheats.</p>
            <button id="closeDisclaimerBtn" class="modal-btn">I Understand</button>
        </div>
    </div>

    <script>
        const amount = parseFloat('<%= amount %>');
        const productName = '<%= productName %>';
        const durationStr = '<%= duration %>';
        let days = 0;
        if (durationStr.includes('Lifetime')) {
            days = 0;
        } else {
            const match = durationStr.match(/\d+/);
            days = match ? parseInt(match[0]) : 0;
        }
        const container = document.getElementById('paypal-button-container');
        const statusDiv = document.getElementById('paymentStatus');
        const overlay = document.getElementById('loadingOverlay');

        async function createOrder() {
            try {
                const response = await fetch('/api/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        amount: amount.toFixed(2),
                        productName: productName,
                        days: days
                    })
                });
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);
                return data.orderId;
            } catch (err) {
                statusDiv.innerHTML = `<div class="error-message">⚠️ ${err.message}</div>`;
                throw err;
            }
        }

        async function onApprove(data) {
            // Show loading overlay with moving lines
            overlay.classList.add('show');
            try {
                const response = await fetch('/api/capture-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId: data.orderID })
                });
                const result = await response.json();
                overlay.classList.remove('show');
                if (response.ok) {
                    statusDiv.innerHTML = '<div class="success-message">✅ Payment successful! Access granted. Redirecting...</div>';
                    setTimeout(() => window.location.href = '/my-orders', 3000);
                } else {
                    throw new Error(result.error);
                }
            } catch (err) {
                overlay.classList.remove('show');
                statusDiv.innerHTML = `<div class="error-message">⚠️ ${err.message}</div>`;
            }
        }

        function onError(err) {
            overlay.classList.remove('show');
            console.error(err);
            statusDiv.innerHTML = '<div class="error-message">⚠️ Payment failed. Please try again.</div>';
        }

        function waitForPayPal() {
            if (window.paypal) {
                container.innerHTML = '';
                window.paypal.Buttons({ createOrder, onApprove, onError }).render('#paypal-button-container');
            } else {
                setTimeout(waitForPayPal, 200);
            }
        }
        waitForPayPal();

        // Logout
        document.getElementById('logoutBtn').addEventListener('click', async () => {
            await fetch('/logout', { method: 'POST' });
            window.location.href = '/';
        });

        // Disclaimer modal (once per session)
        const disclaimerModal = document.getElementById('disclaimerModal');
        const disclaimerSeen = sessionStorage.getItem('winCoD_disclaimer_seen');
        if (!disclaimerSeen && disclaimerModal) {
            disclaimerModal.classList.add('show');
        }
        const closeDisclaimer = document.getElementById('closeDisclaimerBtn');
        if (closeDisclaimer) {
            closeDisclaimer.addEventListener('click', () => {
                disclaimerModal.classList.remove('show');
                sessionStorage.setItem('winCoD_disclaimer_seen', 'true');
            });
        }
    </script>
</body>
</html>