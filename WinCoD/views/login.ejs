<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>WinCoD • Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-page">
    <!-- Animated moving lines (same as shop, but CSS will add extra lines) -->
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>
    <div class="glass-card">
        <div class="logo"><div class="logo-icon">𝕎</div></div>
        <h1>Welcome Back</h1>
        <p class="subtitle">Log in to continue</p>
        <% if (error) { %><div class="error-message"><%= error %></div><% } %>
        <form action="/login" method="POST">
            <input type="hidden" name="redirect" value="<%= redirect %>">
            <div class="input-group"><label>Email</label><input type="email" name="email" required></div>
            <div class="input-group"><label>Password</label><input type="password" name="password" required></div>
            <button type="submit" class="btn btn-primary">Log In</button>
        </form>
        <div class="auth-link">No account? <a href="/register">Create one</a></div>
    </div>
</body>
</html>