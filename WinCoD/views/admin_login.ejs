<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>WinCoD Admin Login</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html, body {
            height: 100%;
        }
        body {
            font-family: 'Orbitron', 'Segoe UI', sans-serif;
            background: #0a0404;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
        }
        /* Moving lines (same as shop) */
        .moving-lines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.4;
            pointer-events: none;
        }
        .line {
            position: absolute;
            background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px;
            width: 100%;
            animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        /* Glass card */
        .glass-card {
            background: rgba(20, 5, 5, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            border: 1px solid rgba(255, 50, 50, 0.6);
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3);
            padding: 40px;
            width: 100%;
            max-width: 450px;
            z-index: 1;
            text-align: center;
        }
        h1 {
            color: white;
            font-size: 28px;
            margin-bottom: 8px;
        }
        .subtitle {
            color: rgba(255, 200, 200, 0.7);
            margin-bottom: 30px;
        }
        .input-group {
            margin-bottom: 20px;
            text-align: left;
        }
        .input-group label {
            display: block;
            color: rgba(255, 200, 200, 0.8);
            margin-bottom: 8px;
        }
        .input-group input {
            width: 100%;
            padding: 12px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,50,50,0.4);
            border-radius: 16px;
            color: white;
            font-size: 16px;
        }
        .btn-primary {
            background: linear-gradient(135deg, #cc0000, #660000);
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            border-radius: 30px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px #ff0000;
        }
        .error-message {
            background: rgba(239,68,68,0.2);
            border: 1px solid rgba(239,68,68,0.4);
            padding: 10px;
            border-radius: 12px;
            color: #fca5a5;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>
    <div class="glass-card">
        <h1>Admin Login</h1>
        <div class="subtitle">Admin: <%= adminEmail %></div>
        <% if (error) { %><div class="error-message"><%= error %></div><% } %>
        <form action="/admin/login" method="POST">
            <div class="input-group"><label>Password</label><input type="password" name="password" required autofocus></div>
            <button type="submit" class="btn-primary">Log In</button>
        </form>
    </div>
</body>
</html>