<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>WinCoD Reports</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Orbitron', 'Segoe UI', sans-serif;
            background: #0a0404;
            padding: 20px;
            position: relative;
        }
        .moving-lines {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.3; pointer-events: none;
        }
        .line {
            position: absolute; background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px; width: 100%; animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        .container { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
        .header { display: flex; justify-content: space-between; align-items: center; background: rgba(20,5,5,0.7); backdrop-filter: blur(8px); padding: 15px 20px; border-radius: 40px; margin-bottom: 20px; border: 1px solid rgba(255,50,50,0.3); }
        h1 { color: white; }
        .btn { background: #667eea; padding: 8px 16px; border-radius: 30px; text-decoration: none; color: white; display: inline-block; }
        .btn-success { background: #22c55e; }
        .card { background: rgba(20,5,5,0.7); backdrop-filter: blur(8px); border-radius: 24px; padding: 20px; margin-bottom: 30px; border: 1px solid rgba(255,50,50,0.4); }
        iframe { width: 100%; height: 600px; border: none; border-radius: 12px; background: white; }
        .excel-preview { background: white; border-radius: 12px; padding: 10px; overflow-x: auto; }
        .success-message { background: #22c55e22; border: 1px solid #22c55e; padding: 10px; border-radius: 12px; color: #4ade80; margin-top: 10px; }
        .error-message { background: #dc262622; border: 1px solid #dc2626; padding: 10px; border-radius: 12px; color: #fca5a5; }
    </style>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
</head>
<body>
    <div class="moving-lines"><div class="line"></div><div class="line"></div><div class="line"></div><div class="line"></div><div class="line"></div><div class="line"></div></div>
    <div class="container">
        <div class="header">
            <h1>📁 Reports</h1>
            <a href="/admin/data" class="btn">← Back to Dashboard</a>
        </div>
        <div class="card">
            <h2 style="color:white;">📊 Export Files</h2>
            <div>
                <% if (excelFile) { %>
                    <a href="/exports/<%= excelFile %>" download class="btn btn-success">⬇️ Download Excel</a>
                <% } else { %><span style="color:#fca5a5;">Excel not found</span><% } %>
                <% if (pdfFile) { %>
                    <a href="/exports/<%= pdfFile %>" download class="btn">⬇️ Download PDF</a>
                    <a href="/exports/<%= pdfFile %>" target="_blank" class="btn">👁️ Preview PDF</a>
                <% } else { %><span style="color:#fca5a5;">PDF not found</span><% } %>
            </div>
            <button id="regenerateBtn" class="btn btn-success" style="margin-top:15px;">🔄 Regenerate Export</button>
            <div id="exportStatus" class="success-message" style="display:none;"></div>
        </div>
        <% if (excelFile) { %>
        <div class="card">
            <h2 style="color:white;">📊 Excel Preview</h2>
            <div id="excelPreviewContainer" class="excel-preview">Loading...</div>
        </div>
        <% } %>
        <% if (pdfFile) { %>
        <div class="card">
            <h2 style="color:white;">📄 PDF Preview</h2>
            <iframe src="/exports/<%= pdfFile %>"></iframe>
        </div>
        <% } %>
    </div>
    <script>
        (function() {
            const hasExcel = <%= excelFile ? 'true' : 'false' %>;
            if (hasExcel) {
                fetch('/exports/transactions_latest.xlsx')
                    .then(res => res.arrayBuffer())
                    .then(data => {
                        const wb = XLSX.read(data, { type: 'array' });
                        const sheet = wb.Sheets[wb.SheetNames[0]];
                        const html = XLSX.utils.sheet_to_html(sheet);
                        document.getElementById('excelPreviewContainer').innerHTML = html;
                    })
                    .catch(err => document.getElementById('excelPreviewContainer').innerHTML = `<div class="error-message">Error: ${err.message}</div>`);
            }
            const regenBtn = document.getElementById('regenerateBtn');
            const statusDiv = document.getElementById('exportStatus');
            if (regenBtn) {
                regenBtn.addEventListener('click', async () => {
                    statusDiv.style.display = 'block'; statusDiv.textContent = '⏳ Generating...';
                    try {
                        const res = await fetch('/admin/export');
                        const data = await res.json();
                        if (res.ok) { statusDiv.textContent = '✅ ' + data.message + ' Reloading...'; setTimeout(() => location.reload(), 2000); }
                        else throw new Error(data.error);
                    } catch (err) { statusDiv.textContent = '❌ ' + err.message; statusDiv.className = 'error-message'; setTimeout(() => statusDiv.style.display = 'none', 5000); }
                });
            }
        })();
    </script>
</body>
</html>