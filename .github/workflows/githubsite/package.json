{
  "name": "admin-panel-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.yourcompany.adminpanel",
    "productName": "Admin Panel",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "asar": false,
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist",
      "!exports",
      "!*.log"
    ],
    "extraResources": [
      {
        "from": "views",
        "to": "views"
      },
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "exceljs": "^3.4.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.14.0"
  },
  "devDependencies": {
    "electron": "^42.3.1",
    "electron-builder": "^26.8.1"
  }
}
