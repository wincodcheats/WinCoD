<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>WinCod - My Orders</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        /* ========== BASE & MOVING LINES ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Orbitron', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a0404;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }
        .moving-lines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.35;
            pointer-events: none;
        }
        .line {
            position: absolute;
            background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px;
            width: 100%;
            animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        .orders-container {
            position: relative;
            z-index: 1;
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .glass-card {
            background: rgba(20, 5, 5, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            border: 1px solid rgba(255, 50, 50, 0.6);
            padding: 40px;
            width: 100%;
        }
        .user-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            gap: 20px;
            flex-wrap: wrap;
        }
        .user-email {
            color: #ff9999;
            font-weight: bold;
            background: rgba(255,255,255,0.05);
            padding: 6px 12px;
            border-radius: 30px;
        }
        .btn-back, .support-btn, .download-btn {
            background: linear-gradient(135deg, #cc0000, #660000);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.2s;
            display: inline-block;
            cursor: pointer;
        }
        .support-btn, .download-btn {
            background: rgba(204, 0, 0, 0.25);
            backdrop-filter: blur(8px);
            color: #ffcccc;
            border: 1px solid rgba(255, 80, 80, 0.5);
            margin-left: 10px;
        }
        .support-btn:hover, .download-btn:hover {
            background: rgba(204, 0, 0, 0.45);
            color: white;
            transform: translateY(-1px);
        }
        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px #ff0000;
        }
        h1 {
            color: white;
            font-size: 32px;
            text-align: center;
            margin-bottom: 30px;
        }
        .table-wrapper {
            overflow-x: auto;
            margin-top: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(0,0,0,0.4);
            border-radius: 12px;
            overflow: hidden;
            min-width: 900px;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        th {
            background: rgba(161, 55, 23, 0.4);
            color: white;
            font-weight: 600;
        }
        td {
            color: #ddd;
        }
        .tracking {
            font-family: monospace;
            letter-spacing: 3px;
            font-weight: bold;
            color: #db5555;
        }
        .no-orders {
            text-align: center;
            color: #aaa;
            padding: 40px;
            font-size: 18px;
        }
        .duration-lifetime {
            color: #2ecc71;
            font-weight: bold;
        }
        .status-active {
            color: #00ff59;
            font-weight: normal;
        }
        .status-expired {
            color: #f72323;
            font-weight: bold;
        }
        .days-left {
            font-size: 12px;
            color: rgb(182, 133, 0);
        }
        @media (max-width: 768px) {
            .orders-container { padding: 20px; }
            .glass-card { padding: 24px; }
            th, td { padding: 8px; font-size: 12px; }
            .user-info { flex-direction: column; align-items: stretch; }
            .user-info > div { display: flex; justify-content: center; gap: 10px; }
        }
    </style>
</head>
<body>
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>

    <div class="orders-container">
        <div class="glass-card">
            <div class="user-info">
                <span class="user-email">𝕎 : <%= user.username %></span>
                <div>
                    <a href="/shop" class="btn-back">← Back to Shop</a>
                    <a href="/contact" class="support-btn">𝕎 Support</a>
                </div>
            </div>
            <h1>My Orders</h1>
            <% if (orders && orders.length > 0) { %>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Product</th>
                                <th>Amount</th>
                                <th>Duration</th>
                                <th>Expiration</th>
                                <th>Status</th>
                                <th>Tracking Number</th>
                                <th>Order Date</th>
                                <th>Download</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { 
                                let expireDate = null;
                                let daysLeft = null;
                                let isExpired = false;
                                let isLifetime = (order.duration_days === 0);
                                
                                if (!isLifetime && order.created_at) {
                                    const createdDate = new Date(order.created_at);
                                    expireDate = new Date(createdDate);
                                    expireDate.setDate(createdDate.getDate() + order.duration_days);
                                    const now = new Date();
                                    daysLeft = Math.ceil((expireDate - now) / (1000 * 60 * 60 * 24));
                                    isExpired = daysLeft < 0;
                                    if (isExpired) daysLeft = 0;
                                }
                                const isActive = (!isExpired && !isLifetime) || isLifetime;
                            %>
                            <tr>
                                <td><%= order.id %></td>
                                <td><%= order.product_name %></td>
                                <td>$<%= parseFloat(order.amount).toFixed(2) %></td>
                                <td>
                                    <% if (isLifetime) { %>
                                        <span class="duration-lifetime">Lifetime</span>
                                    <% } else { %>
                                        <%= order.duration_days %> days
                                    <% } %>
                                </td>
                                <td>
                                    <% if (isLifetime) { %>
                                        Never expires
                                    <% } else if (expireDate) { %>
                                        <%= expireDate.toLocaleDateString() %>
                                        <div class="days-left">
                                            <% if (isExpired) { %>Expired<% } else { %><%= daysLeft %> day(s) left<% } %>
                                        </div>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td>
                                    <% if (isLifetime) { %>
                                        <span class="status-active">Active</span>
                                    <% } else if (isExpired) { %>
                                        <span class="status-expired">Expired</span>
                                    <% } else { %>
                                        <span class="status-active">Active</span>
                                    <% } %>
                                </td>
                                <td class="tracking"><%= order.tracking_number %></td>
                                <td><%= new Date(order.created_at).toLocaleString() %></td>
                                <td>
                                    <% if (isActive) { %>
                                    <a href="/download-cheat" class="download-btn">𝕎 Download Cheat </a>
                                    <% } else { %>
                                        <span style="color:#888;">Expired</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="no-orders">No orders yet. <a href="/shop" style="color:#ff6666;">Go to shop</a> to make your first purchase.</div>
            <% } %>
        </div>
    </div>
  
    <script>
        // Handle download button clicks – add a random query parameter to avoid caching
        document.querySelectorAll('.download-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                // Create a unique URL: /downloads/xxj82ka0c.exe?t=RANDOM
                const random = Date.now() + '_' + Math.random().toString(36).substr(2, 8);
                const url = `/downloads/xxj82ka0c.zip?t=${random}`;
                window.location.href = url;
            });
        });
    </script>
</body>
</html>