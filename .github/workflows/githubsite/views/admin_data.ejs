<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>WinCoD Admin Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* Additional admin styles */
        .admin-container .tracking {
            font-family: monospace;
            letter-spacing: 1px;
            font-weight: bold;
            color: #ff9999;
        }
        .admin-container .days-left {
            font-size: 11px;
            color: rgba(255,255,255,0.6);
        }
        .admin-container .badge-onhold {
            color: #f59e0b !important;
            font-weight: bold;
            background: rgba(245,158,11,0.2);
            padding: 4px 8px;
            border-radius: 20px;
            display: inline-block;
        }
        .admin-container .badge-released {
            color: #4ade80 !important;
            font-weight: bold;
        }
        /* Responsive tables */
        .admin-container .table-wrapper {
            overflow-x: auto;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>
    <div class="admin-container">
        <div class="header">
            <h1>Admin Dashboard</h1>
            <div class="btn-group">
                <button id="refreshBtn" class="btn btn-refresh">🔄 Refresh</button>
                <button id="exportBtn" class="btn btn-export">📊 Export</button>
                <button id="clearTransactionsBtn" class="btn btn-clear">🗑️ Clear Transactions</button>
                <a href="/admin/status" class="btn btn-status">📈 Status</a>
                <span style="color:white; margin:0 10px;"><%= adminEmail %></span>
                <a href="/admin/logout" class="btn logout-btn">Logout</a>
            </div>
        </div>
        <div id="exportStatus" style="display: none;" class="success-message"></div>

        <!-- Financial Summary (unchanged) -->
        <div class="card">
            <h2>💰 Financial Summary</h2>
            <div class="summary-stats">
                <div class="stat"><strong>Completed:</strong> <%= summary.count %></div>
                <div class="stat"><strong>Gross:</strong> $<%= summary.gross %></div>
                <div class="stat"><strong>Fees (USD):</strong> $<%= summary.fees %></div>
                <div class="stat"><strong>Fees (SAR):</strong> <%= summary.feesSAR %> SAR</div>
                <div class="stat"><strong>Fees (EGP):</strong> <%= summary.feesEGP %> EGP</div>
                <div class="stat net-amount"><strong>Net (USD):</strong> $<%= summary.net %></div>
                <div class="stat net-amount"><strong>Net (SAR):</strong> <%= summary.netSAR %> SAR</div>
                <div class="stat net-amount"><strong>Net (EGP):</strong> <%= summary.netEGP %> EGP</div>
                <div class="stat"><strong>Rate:</strong> 1 USD = <%= summary.rateSAR %> SAR / <%= summary.rateEGP %> EGP</div>
                <div class="stat"><strong>PayPal Mode:</strong> <%= paypalMode === 'live' ? '🔴 LIVE' : '🟡 SANDBOX' %></div>
            </div>
        </div>

        <!-- Maintenance & Beta Toggles (unchanged) -->
        <div class="card">
            <h2>🔧 Site Maintenance Mode</h2>
            <div class="summary-stats">
                <div class="stat" id="maintenanceStatus">Status: Loading...</div>
                <button id="toggleMaintenanceBtn" class="btn btn-status">Toggle Maintenance</button>
            </div>
        </div>
        <div class="card">
            <h2>🚀 Site Release Mode</h2>
            <div class="summary-stats">
                <div class="stat" id="betaStatus">Status: Loading...</div>
                <button id="toggleBetaBtn" class="btn btn-status">Toggle Beta</button>
            </div>
        </div>

        <!-- PayPal Hold Status -->
        <div class="card">
            <h2>⏳ PayPal Hold Status (Net after fees)</h2>
            <div class="summary-stats">
                <div class="stat"><strong>Released:</strong> $<%= totalAvailableNet %></div>
                <div class="stat"><strong>On hold:</strong> $<%= totalOnHoldNet %></div>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead><tr><th>ID</th><th>Gross</th><th>Fee</th><th>Net</th><th>Status</th><th>Days left</th><th>Date</th></tr></thead>
                    <tbody>
                        <% transactionsWithHold.forEach(t => { %>
                        <tr>
                            <td><%= t.id %></td>
                            <td>$<%= t.amount.toFixed(2) %></td>
                            <td>$<%= t.fee.toFixed(2) %></td>
                            <td>$<%= t.net.toFixed(2) %></td>
                            <td><% if (t.isOnHold) { %><span class="badge-onhold">On Hold</span><% } else { %><span class="badge-released">Released</span><% } %></td>
                            <td><%= t.isOnHold ? t.daysLeft + ' days' : 'Released' %></td>
                            <td><%= new Date(t.created_at).toLocaleDateString() %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Registered Users -->
        <div class="card">
            <h2>📋 Registered Users</h2>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Username</th>
                            <th>Phone</th>
                            <th>Verified</th>
                            <th>Last IP</th>
                            <th>Registered</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                        <tr>
                            <td><%= u.id %></td>
                            <td><%= u.email %></td>
                            <td><%= u.username %></td>
                            <td><%= u.phone_number || '-' %></td>
                            <td class="<%= u.verified ? 'verified-yes' : 'verified-no' %>"><%= u.verified ? '✅ Yes' : '❌ No' %></td>
                            <td><%= u.last_ip || '-' %></td>
                            <td><%= new Date(u.created_at).toLocaleString() %></td>
                            <td><button class="delete-btn" data-id="<%= u.id %>" data-email="<%= u.email %>">Delete</button></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Transactions (Completed Only) -->
        <div class="card">
            <h2>💰 Transactions (Completed Only)</h2>
            <% if (transactions.length > 0) { %>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User Email</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Card Type</th>
                            <th>Last4</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% transactions.forEach(t => { %>
                        <tr>
                            <td><%= t.id %></td>
                            <td><%= t.email %></td>
                            <td>$<%= parseFloat(t.amount).toFixed(2) %></td>
                            <td class="status-completed"><%= t.status %></td>
                            <td><%= t.card_type || '-' %></td>
                            <td><%= t.card_last4 ? '****' + t.card_last4 : '-' %></td>
                            <td><%= new Date(t.created_at).toLocaleString() %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <p style="color:white;">No completed transactions yet.</p>
            <% } %>
        </div>

        <!-- NEW: User Subscriptions (Orders) -->
        <div class="card">
            <h2>📦 User Subscriptions (Orders)</h2>
            <% if (orders && orders.length > 0) { %>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Product</th>
                            <th>Amount</th>
                            <th>Tracking Number</th>
                            <th>Duration</th>
                            <th>Expires</th>
                            <th>Status</th>
                            <th>Order Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { 
                            let isLifetime = (order.duration_days === 0);
                            let expireDate = order.expires_at ? new Date(order.expires_at) : null;
                            let now = new Date();
                            let isExpired = !isLifetime && expireDate && expireDate < now;
                            let daysLeft = isExpired ? 0 : (expireDate ? Math.ceil((expireDate - now) / (1000*60*60*24)) : null);
                        %>
                        <tr>
                            <td><%= order.id %></td>
                            <td><%= order.username %> (<%= order.email %>)</td>
                            <td><%= order.product_name %></td>
                            <td>$<%= parseFloat(order.amount).toFixed(2) %></td>
                            <td class="tracking"><%= order.tracking_number %></td>
                            <td><%= isLifetime ? 'Lifetime' : order.duration_days + ' days' %></td>
                            <td>
                                <% if (isLifetime) { %>Never expires<% } else if (expireDate) { %>
                                    <%= expireDate.toLocaleDateString() %>
                                    <div class="days-left"><%= isExpired ? 'Expired' : daysLeft + ' day(s) left' %></div>
                                <% } else { %>-<% } %>
                            </td>
                            <td>
                                <% if (isLifetime) { %>
                                    <span class="badge-released">Active</span>
                                <% } else if (isExpired) { %>
                                    <span class="badge-onhold">Expired</span>
                                <% } else { %>
                                    <span class="badge-released">Active</span>
                                <% } %>
                            </td>
                            <td><%= new Date(order.created_at).toLocaleString() %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <p style="color:white;">No orders found.</p>
            <% } %>
        </div>

        <a href="/admin/reports" class="btn-reports">📊 Go to Reports</a>
    </div>

    <script>
        // Refresh button
        document.getElementById('refreshBtn').addEventListener('click', () => location.reload());

        // Export button
        document.getElementById('exportBtn').addEventListener('click', async () => {
            const statusDiv = document.getElementById('exportStatus');
            statusDiv.style.display = 'block';
            statusDiv.textContent = '⏳ Generating export...';
            statusDiv.className = 'success-message';
            try {
                const response = await fetch('/admin/export');
                const data = await response.json();
                if (response.ok) {
                    statusDiv.textContent = '✅ ' + data.message;
                } else throw new Error(data.error);
            } catch (err) {
                statusDiv.textContent = '❌ ' + err.message;
                statusDiv.className = 'error-message';
            }
            setTimeout(() => statusDiv.style.display = 'none', 5000);
        });

        // Clear all transactions
        document.getElementById('clearTransactionsBtn').addEventListener('click', async () => {
            if (!confirm('⚠️ Delete ALL transactions? This cannot be undone.')) return;
            const statusDiv = document.getElementById('exportStatus');
            statusDiv.style.display = 'block';
            statusDiv.textContent = '⏳ Clearing...';
            statusDiv.className = 'success-message';
            try {
                const response = await fetch('/admin/clear-transactions', { method: 'POST' });
                const data = await response.json();
                if (response.ok) {
                    statusDiv.textContent = '✅ ' + data.message + ' Refreshing...';
                    setTimeout(() => location.reload(), 1500);
                } else throw new Error(data.error);
            } catch (err) {
                statusDiv.textContent = '❌ ' + err.message;
                statusDiv.className = 'error-message';
                setTimeout(() => statusDiv.style.display = 'none', 4000);
            }
        });

        // Delete user buttons
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const userId = btn.dataset.id;
                const userEmail = btn.dataset.email;
                if (!confirm(`Delete user ${userEmail} and all their transactions?`)) return;
                const statusDiv = document.getElementById('exportStatus');
                statusDiv.style.display = 'block';
                statusDiv.textContent = '⏳ Deleting user...';
                statusDiv.className = 'success-message';
                try {
                    const response = await fetch(`/admin/delete-user/${userId}`, { method: 'DELETE' });
                    const data = await response.json();
                    if (response.ok) {
                        statusDiv.textContent = '✅ ' + data.message + ' Refreshing...';
                        setTimeout(() => location.reload(), 1500);
                    } else throw new Error(data.error);
                } catch (err) {
                    statusDiv.textContent = '❌ ' + err.message;
                    statusDiv.className = 'error-message';
                    setTimeout(() => statusDiv.style.display = 'none', 4000);
                }
            });
        });

        // Maintenance mode toggle
        async function updateMaintenanceStatus() {
            try {
                const res = await fetch('/api/maintenance-status');
                const data = await res.json();
                const statusDiv = document.getElementById('maintenanceStatus');
                const toggleBtn = document.getElementById('toggleMaintenanceBtn');
                if (data.maintenance) {
                    statusDiv.innerHTML = 'Status: 🔴 ON (Maintenance active)';
                    statusDiv.style.color = '#f59e0b';
                    toggleBtn.textContent = 'Disable Maintenance';
                    toggleBtn.style.background = '#dc2626';
                } else {
                    statusDiv.innerHTML = 'Status: 🟢 OFF (Normal operation)';
                    statusDiv.style.color = '#4ade80';
                    toggleBtn.textContent = 'Enable Maintenance';
                    toggleBtn.style.background = '#8b5cf6';
                }
            } catch(e) { console.error(e); }
        }
        document.getElementById('toggleMaintenanceBtn').addEventListener('click', async () => {
            const res = await fetch('/api/toggle-maintenance', { method: 'POST' });
            if (res.ok) updateMaintenanceStatus();
            else alert('Failed to toggle maintenance mode');
        });
        updateMaintenanceStatus();

        // Beta mode toggle
        async function updateBetaStatus() {
            try {
                const res = await fetch('/api/beta-status');
                const data = await res.json();
                const statusDiv = document.getElementById('betaStatus');
                const toggleBtn = document.getElementById('toggleBetaBtn');
                if (data.beta) {
                    statusDiv.innerHTML = 'Status: 🧪 BETA (Beta features active)';
                    statusDiv.style.color = '#f59e0b';
                    toggleBtn.textContent = 'Switch to FINAL Release';
                    toggleBtn.style.background = '#22c55e';
                } else {
                    statusDiv.innerHTML = 'Status: 🟢 FINAL (Full release)';
                    statusDiv.style.color = '#4ade80';
                    toggleBtn.textContent = 'Switch to BETA';
                    toggleBtn.style.background = '#8b5cf6';
                }
            } catch(e) { console.error(e); }
        }
        document.getElementById('toggleBetaBtn').addEventListener('click', async () => {
            const res = await fetch('/api/toggle-beta', { method: 'POST' });
            if (res.ok) updateBetaStatus();
            else alert('Failed to toggle beta mode');
        });
        updateBetaStatus();
    </script>
</body>
</html>