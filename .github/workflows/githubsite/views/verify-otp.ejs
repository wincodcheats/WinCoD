<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WinCoD - Verify Your Register</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Orbitron', 'Segoe UI', sans-serif;
            background: #0a0404;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            padding: 20px;
        }
        /* Moving lines background (same as other auth pages) */
        .moving-lines {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.3; pointer-events: none;
        }
        .line {
            position: absolute; background: linear-gradient(90deg, transparent, #b30000, #ff1a1a, #990000, transparent);
            height: 2px; width: 100%; animation: moveLine 8s linear infinite;
        }
        @keyframes moveLine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .line:nth-child(1) { top: 10%; animation-duration: 12s; width: 80%; left: 10%; }
        .line:nth-child(2) { top: 25%; animation-duration: 9s; width: 85%; left: 7%; }
        .line:nth-child(3) { top: 40%; animation-duration: 15s; width: 90%; left: 5%; }
        .line:nth-child(4) { top: 55%; animation-duration: 7s; width: 75%; left: 12%; }
        .line:nth-child(5) { top: 70%; animation-duration: 11s; width: 95%; left: 2%; }
        .line:nth-child(6) { top: 85%; animation-duration: 13s; width: 85%; left: 8%; }

        .glass-card {
            background: rgba(20, 5, 5, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            border: 1px solid rgba(255, 50, 50, 0.6);
            padding: 40px;
            width: 100%;
            max-width: 450px;
            position: relative;
            z-index: 1;
            text-align: center;
        }
        h1 { color: white; margin-bottom: 16px; }
        p { color: rgba(255,200,200,0.8); margin-bottom: 20px; }
        .input-group input {
            width: 100%; padding: 12px; background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,50,50,0.4); border-radius: 16px;
            color: white; font-size: 16px; text-align: center;
        }
        .btn-primary {
            background: linear-gradient(135deg, #cc0000, #660000);
            color: white; border: none; padding: 12px; width: 100%;
            border-radius: 30px; font-weight: bold; cursor: pointer;
            margin-top: 20px;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px #ff0000;
        }
        .auth-link { margin-top: 20px; }
        .auth-link a { color: #ff6666; text-decoration: none; }
        .error-message {
            background: rgba(239,68,68,0.2);
            border: 1px solid rgba(239,68,68,0.4);
            padding: 10px;
            border-radius: 12px;
            color: #fca5a5;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="moving-lines">
        <div class="line"></div><div class="line"></div><div class="line"></div>
        <div class="line"></div><div class="line"></div><div class="line"></div>
    </div>
    <div class="glass-card">
        <h1>Verify Email</h1>
        <p>We sent a 6-digit code to <strong><%= email %></strong></p>
        <div id="errorMsg" class="error-message" style="display:none;"></div>
        <div class="input-group"><input type="text" id="otp" maxlength="6" placeholder="Enter OTP"></div>
        <button id="verifyBtn" class="btn-primary">Verify</button>
        <div class="auth-link"><a href="#" id="resendLink">Resend Code</a></div>
    </div>
    <script>
        document.getElementById('verifyBtn').onclick = async () => {
            const otp = document.getElementById('otp').value.trim();
            if (!otp) return;
            const res = await fetch('/api/verify-otp', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({otp}) });
            const data = await res.json();
            if (res.ok) window.location.href = data.redirect;
            else { document.getElementById('errorMsg').style.display='block'; document.getElementById('errorMsg').textContent=data.error; }
        };
        document.getElementById('resendLink').onclick = async (e) => {
            e.preventDefault();
            await fetch('/api/resend-otp', { method:'POST' });
            alert('New OTP sent');
        };
    </script>
</body>
</html>